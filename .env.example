APP_ORIGIN=http://localhost:5173
VIEW_ORIGIN=http://localhost:5174
DB_PATH=./data/confer.db
BLOB_DIR=./blobs
SIGNING_SECRET=dev-only-change-me
PORT=5173
VIEW_PORT=5174
SLACK_WEBHOOK_URL=

# Cloudflare R2 / S3-compatible blob storage (optional).
# When all four of R2_BUCKET + R2_ACCESS_KEY_ID + R2_SECRET_ACCESS_KEY + R2_ENDPOINT
# are set, blobs go to R2 instead of the local BLOB_DIR disk store.
# R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# R2_REGION=auto
# R2_BUCKET=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_FORCE_PATH_STYLE=false