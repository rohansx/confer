{
  "name": "confer",
  "private": true,
  "workspaces": ["shared", "server"],
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p server/tsconfig.json && tsc --noEmit -p shared/tsconfig.json",
    "dev": "npm run dev --workspace @confer/server",
    "start": "npm run start --workspace @confer/server"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0"
  }
}
