{
  "name": "confer",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "web",
    "cli"
  ],
  "type": "module",
  "packageManager": "npm@11.16.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:watch": "turbo run test --watch",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "dev:origins": "turbo run dev --filter=@confer/server",
    "dev:web": "turbo run dev --filter=@confer/web",
    "dev:cli": "npm run start --workspace @confer/cli --",
    "start": "npm run start --workspace @confer/server"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "turbo": "^2.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}